# ─── AI Kitchen Assistant — Environment Variables ───────────────────────────
# Rename this file to ".env" and fill in your real values.
# NEVER commit the actual .env file to git.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL: Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Service Role Key (has full DB access — keep secret):
# Supabase dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Gemini / Google AI ────────────────────────────────────────────────────────
# Google AI Studio → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── App Config ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret
FRONTEND_URL=http://localhost:3000
